---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "BBSW 2026", description = "Bay Area Biotech-Pharma Statistics Workshop 2026" } = Astro.props;
const base = import.meta.env.BASE_URL;
const link = (p: string) => `${base}${p}`.replace(/\/\//g, "/");

// Detect current top-level slug to highlight the active tab.
const baseClean = base.replace(/\/$/, "");
const path = Astro.url.pathname;
const slug = path.replace(baseClean, "").replace(/^\//, "").split("/")[0] || "";

const slugToTab: Record<string, string> = {
  "": "home",
  "schedule": "schedule",
  "sessions": "schedule",
  "speakers": "speakers",
  "posters": "posters",
  "sponsors": "home",
  "venue": "venue",
};
const currentTab = slugToTab[slug] ?? "home";

const tabs = [
  { slug: "home", href: link(""), label: "Home" },
  { slug: "schedule", href: link("schedule"), label: "Schedule" },
  { slug: "speakers", href: link("speakers"), label: "Speakers" },
  { slug: "posters", href: link("posters"), label: "Posters" },
  { slug: "venue", href: link("venue"), label: "Venue" },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#9b1b30" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={link("favicon.svg")} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={link("apple-touch-icon.png")} />
    <link rel="manifest" href={link("manifest.webmanifest")} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="BBSW 2026" />
    <meta name="mobile-web-app-capable" content="yes" />
  </head>
  <body>
    <header class="site-header">
      <a href={link("")} class="brand" aria-label="BBSW 2026 home">
        <img src={link("bbsw-logo.webp")} alt="BBSW — Bay Area Biotech-Pharma Statistics Workshop" />
        <span class="brand-text">2026</span>
      </a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>BBSW 2026 · November 5–6, 2026 · Foster City, CA</p>
      <p><a href="https://bbsw.org">bbsw.org</a></p>
    </footer>
    <nav class="tab-bar" aria-label="Primary">
      {tabs.map((t) => (
        <a href={t.href} class={t.slug === currentTab ? "active" : ""} aria-current={t.slug === currentTab ? "page" : undefined}>
          <span class="tab-icon-bg">
            {t.slug === "home" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l9-8 9 8v10a2 2 0 0 1-2 2h-4v-7h-6v7H5a2 2 0 0 1-2-2z"/></svg>
            )}
            {t.slug === "schedule" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>
            )}
            {t.slug === "speakers" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20a6.5 6.5 0 0 1 13 0"/><circle cx="17" cy="9" r="2.5"/><path d="M15 20a5 5 0 0 1 6.5-4.8"/></svg>
            )}
            {t.slug === "posters" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>
            )}
            {t.slug === "venue" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s-7-7.5-7-13a7 7 0 0 1 14 0c0 5.5-7 13-7 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
            )}
          </span>
          <span>{t.label}</span>
        </a>
      ))}
    </nav>
    <script is:inline define:vars={{ swPath: link("sw.js"), swScope: base }}>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register(swPath, { scope: swScope }).catch(() => {});
        });
      }
    </script>
  </body>
</html>
