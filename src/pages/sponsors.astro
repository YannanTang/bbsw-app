---
import BaseLayout from "../layouts/BaseLayout.astro";
import sponsors from "../data/sponsors.json";

type Sponsor = { name: string; tier: string; logo: string; website: string; };
const tiers = ["Platinum", "Gold", "Silver", "Bronze"];
const grouped: Record<string, Sponsor[]> = {};
for (const s of sponsors as Sponsor[]) {
  (grouped[s.tier] ||= []).push(s);
}
---
<BaseLayout title="Sponsors — BBSW 2026">
  <h1>Sponsors</h1>
  <p>Thank you to our 2026 sponsors. Placeholder tiers below.</p>
  {tiers.map((tier) => grouped[tier] && (
    <section class="sponsor-tier">
      <h2>{tier}</h2>
      <div class="sponsor-grid">
        {grouped[tier].map((sp) => (
          <a class="sponsor-tile" href={sp.website} target="_blank" rel="noopener">
            {sp.logo ? <img src={sp.logo} alt={sp.name} style="max-width:100%;max-height:60px;" /> : <strong>{sp.name}</strong>}
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
